@model IEnumerable<EFA.Models.Category>

@{
    ViewBag.Title = "Categories";
}

<h2>@ViewBag.Title</h2>

<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Name)
        </th>
        <th>

            <a href="@Url.Action("Create", "Categories")">
                <img src="@Url.Content("~/Content/UI_Images/Add.png")" style="height: 25px; width: 25px" />
            </a>
        </th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Name)
        </td>
        <td>
            <a href="@Url.Action("Edit", "Categories", item)">
                <img src="@Url.Content("~/Content/UI_Images/Edit.png")" style="height: 25px; width: 25px" />
            </a>
            <a href="@Url.Action("Delete", "Categories", item)">
                <img src="@Url.Content("~/Content/UI_Images/Delete.png")" style="height: 25px; width: 25px" />
            </a>
        </td>
    </tr>
}

</table>
